      "options": { "orientation": "horizontal" },
      "targets": [
        { "expr": "detection_correlated_alerts_total", "legendFormat": "{{rule_id}} {{label}}" }
      ]
    },
    {
      "id": 7,
      "title": "Requêtes MySQL par type",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 14 },
      "datasource": "Prometheus",
      "targets": [
        { "expr": "rate(db_queries_total[1m])", "legendFormat": "{{command_type}}" }
      ]
    }
