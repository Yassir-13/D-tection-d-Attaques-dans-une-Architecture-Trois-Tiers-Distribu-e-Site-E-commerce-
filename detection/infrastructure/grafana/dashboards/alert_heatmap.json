  "panels": [
    {
      "id": 1,
      "title": "Total alertes critiques (24h)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      },
      "targets": [
        { "expr": "sum(detection_alerts_total{severity=\"critical\"})", "legendFormat": "Critical" }
      ]
    },
    {
      "id": 2,
      "title": "Total alertes high (24h)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 }
            ]
          }
        }
      },
      "targets": [
        { "expr": "sum(detection_alerts_total{severity=\"high\"})", "legendFormat": "High" }
      ]
    },
    {
      "id": 3,
      "title": "Alertes corrélées total",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": "Prometheus",
      "targets": [
        { "expr": "sum(detection_correlated_alerts_total)", "legendFormat": "Corrélées" }
      ]
    },
    {
      "id": 4,
      "title": "Sessions brute-force actives",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      },
      "targets": [
        { "expr": "app_brute_force_sessions", "legendFormat": "Brute-force" }
      ]
    },
    {
      "id": 5,
      "title": "Distribution des attaques par type",
      "type": "piechart",
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 4 },
      "datasource": "Prometheus",
      "targets": [
        { "expr": "sum by (attack_type) (detection_alerts_total)", "legendFormat": "{{attack_type}}" }
      ]
    },
    {
      "id": 6,
      "title": "Règles CEP déclenchées",
      "type": "bargauge",
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 4 },
